   84          uint32 bluetooth_ch9141_send_buff (uint8 *buff, uint32 len)
   85          {
   86   1          uint16 time_count = 0;
   87   1          while(len > 30)
   88   1          {
   89   2              time_count = 0;
   90   2              while(BLUETOOTH_CH9141_RTS_PIN && time_count++ < BLUETOOTH_CH9141_TIMEOUT_COUNT)  // ШчЙћRTSЮЊЕЭЕ
             -чЦНЃЌдђМЬајЗЂЫЭЪ§Он
   91   2                  delay_ms(1);
   92   2              if(time_count >= BLUETOOTH_CH9141_TIMEOUT_COUNT)
   93   2                  return len;                                                         // ФЃПщУІ,ШчЙћдЪаэЕБЧАГЬа
             -ђЪЙгУwhileЕШД§ дђПЩвдЪЙгУКѓУцзЂЪЭЕФwhileЕШД§гяОфЬцЛЛБОifгяОф
   94   2              uart_putbuff(BLUETOOTH_CH9141_INDEX, buff, 30);
   95   2      
   96   2              buff += 30;                                                             // ЕижЗЦЋвЦ
   97   2              len -= 30;                                                              // Ъ§СП
   98   2          }
   99   1      
  100   1          time_count = 0;
  101   1          while(BLUETOOTH_CH9141_RTS_PIN && time_count++ < BLUETOOTH_CH9141_TIMEOUT_COUNT)      // ШчЙћRTSЮЊЕЭЕ
             -чЦНЃЌдђМЬајЗЂЫЭЪ§Он
