   68          // 函数简介     根据err_abs选择分段PID
   69          // 参数说明     err_abs  误差值
   70          // 返回参数     SteerSeg_t*
   71          // 使用示例     select_steer_seg(4) 当前ADC计算后返回的误差的绝对值为4
   72          // 备注信息     将PID分成了STEER_SEGMENTS段，每段都有一个err阈值（err_max_abs），未超过该阈值则使用该段PI
             -D，超过则使用下一段PID
   73          //-------------------------------------------------------------------------------------------------------
             -------------
   74          static SteerSeg_t* select_steer_seg(float err_abs)
   75          {
   76   1          int i;
   77   1          /* 判断当前误差属于哪个分段 */
   78   1          for (i = 0; i < STEER_SEGMENTS; ++i) {
   79   2              if (err_abs <= g_steer_seg[i].err_max_abs) return &g_steer_seg[i];
   80   2          }
   81   1          /* 索引是长度-1 */
   82   1          return &g_steer_seg[STEER_SEGMENTS - 1];
   83   1      }
