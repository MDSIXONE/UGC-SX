   56   1          if (dt <= EPS_F)
   57   1              dt = EPS_F;
   58   1      
   59   1          err = setpoint - measurement;
   60   1      
   61   1          /* P */
   62   1          up = p->kp * err;
   63   1      
   64   1          /* I */
   65   1          p->integ += p->ki * err * dt;
   66   1      
   67   1          /* D (差分近似) */
   68   1          deriv = (err - p->prev_err) / dt;
   69   1          ud = p->kd * deriv;
   70   1      
   71   1          /* 合成 */
   72   1          u = up + p->integ + ud;
