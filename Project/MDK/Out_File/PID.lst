  106          float PID_Update_Velocity(PID_t *p, float setpoint, float measurement)
  107          {
  108   1          float dt;
  109   1          float err;
  110   1      
  111   1          float delta_p;
  112   1          float delta_i;
  113   1          float delta_d;
  114   1      
  115   1          float deriv;
  116   1          float delta_u;
  117   1      
C251 COMPILER V5.60.0,  PID                                                                10/01/26  18:27:31  PAGE 3   

  118   1          if (!p)
  119   1              return 0.0f;
  120   1      
  121   1          dt = (float)p->dt_ms * 0.001f;
  122   1          if (dt <= EPS_F)
  123   1              dt = EPS_F;
  124   1      
  125   1          err = setpoint - measurement;
  126   1      
  127   1          /* ΔP = Kp*(err - prev_err) */
  128   1          delta_p = p->kp * (err - p->prev_err);
  129   1      
  130   1          /* ΔI = Ki*err*dt */
  131   1          delta_i = p->ki * err * dt;
  132   1          if (delta_i > 30.0f) delta_i = 30.0f;
  133   1          else if (delta_i < -30.0f) delta_i = -30.0f;
  134   1          /* ΔD = Kd*((err-prev_err)/dt - prev_deriv) */
  135   1          deriv = (err - p->prev_err) / dt;
  136   1          delta_d = p->kd * (deriv - p->prev_deriv);
  137   1      
  138   1          delta_u = delta_p + delta_i + delta_d;
  139   1      
  140   1          /* 更新内部状态 */
  141   1          p->prev_deriv = deriv;
  142   1          p->prev_err = err;
  143   1      
  144   1          return delta_u;
  145   1      }
