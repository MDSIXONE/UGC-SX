   74   1          /* 输出限幅 + 积分反向修正（防积分风up）*/
   75   1          if (u > p->out_max)
   76   1          {
   77   2              if (p->ki * err * dt > 0.0f)
   78   2              {
   79   3                  p->integ -= p->ki * err * dt;
   80   3              }
   81   2              u = p->out_max;
   82   2          }
   83   1          else if (u < p->out_min)
   84   1          {
   85   2              if (p->ki * err * dt < 0.0f)
   86   2              {
   87   3                  p->integ -= p->ki * err * dt;
   88   3              }
   89   2              u = p->out_min;
   90   2          }
   91   1      
   92   1          p->prev_err = err;
   93   1          p->prev_deriv = deriv;
   94   1      
   95   1          return u;
   96   1      }
